    "paragraphs": [
      {
        "paragraphId": "p-1",
        "text": "本合同为采购框架协议，双方就交付与付款作出约定。"
      }
    ],
    "expectation": {
      "minOpinions": 1,
      "titleContains": "保密",
      "sourceType": "RULE",
      "minRiskLevel": "HIGH"
    }
  },
  {
