## ==================== MySQL ====================
MYSQL_DATABASE=laby-system
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306

## ==================== Redis ====================
REDIS_HOST=laby-redis
REDIS_PORT=6379

## ==================== Qdrant（AI 向量库） ====================
QDRANT_HOST=laby-qdrant
QDRANT_PORT=6334
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

## ==================== RabbitMQ ====================
RABBITMQ_HOST=laby-rabbitmq
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=rabbit
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

## ==================== RocketMQ（profile: rocketmq） ====================
ROCKETMQ_NAMESERVER=laby-rocketmq-nameserver:9876
ROCKETMQ_NAMESERVER_PORT=9876
ROCKETMQ_BROKER_PORT=10911

## ==================== OnlyOffice ====================
ONLYOFFICE_PORT=8088
ONLYOFFICE_ENABLED=true
ONLYOFFICE_JWT_SECRET=laby-onlyoffice-dev-secret-change-me
ONLYOFFICE_URL=http://laby-onlyoffice/
# DS 容器回调宿主机后端（Windows/Mac 用 host.docker.internal）
ONLYOFFICE_CALLBACK_BASE_URL=http://host.docker.internal:48080/admin-api

## ==================== PDF 解析适配层 ====================
PARSE_ADAPTER_PORT=8000
PARSE_ADAPTER_ENABLED=true
PARSE_ADAPTER_URL=http://laby-parse-adapter:8000

## ==================== Docling 解析适配层（DOC/DOCX/XLSX 等） ====================
PARSE_DOCLING_PORT=8001
PARSE_DOCLING_ENABLED=false
PARSE_DOCLING_URL=http://laby-docling-adapter:8001

## ==================== 后端 API ====================
SERVER_PORT=48080
SPRING_PROFILES_ACTIVE=local
JAVA_OPTS=-Xms2g -Xmx2g -Djava.security.egd=file:/dev/./urandom

MASTER_DATASOURCE_URL=jdbc:mysql://laby-mysql:3306/${MYSQL_DATABASE}?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true
MASTER_DATASOURCE_USERNAME=root
MASTER_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD}
SLAVE_DATASOURCE_URL=${MASTER_DATASOURCE_URL}
SLAVE_DATASOURCE_USERNAME=${MASTER_DATASOURCE_USERNAME}
SLAVE_DATASOURCE_PASSWORD=${MASTER_DATASOURCE_PASSWORD}

## ==================== 管理端 ====================
ADMIN_PORT=8080
NODE_ENV=production
PUBLIC_PATH=/
VUE_APP_TITLE=Laby管理系统
VUE_APP_BASE_API=/prod-api
VUE_APP_APP_NAME=/
VUE_APP_TENANT_ENABLE=true
VUE_APP_CAPTCHA_ENABLE=true
VUE_APP_DOC_ENABLE=true
VUE_APP_BAIDU_CODE=fadc1bd5db1a1d6f581df60a1807f8ab
